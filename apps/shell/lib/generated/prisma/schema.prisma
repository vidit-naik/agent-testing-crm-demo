// Prisma schema - works with both SQLite (local) and PostgreSQL (Supabase)
// Switch databases: npm run db:use:sqlite or npm run db:use:postgres

generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// PostgreSQL configuration (Supabase)
datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_DIRECT_URL")
}

model Account {
  id           String   @id @default(uuid())
  name         String
  industry     String?
  companySize  String?  @map("company_size")
  owner        String?
  healthStatus String?  @default("Good") @map("health_status")
  arr          Decimal?
  website      String?
  phone        String?
  address      String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  contacts      Contact[]
  opportunities Opportunity[]
  activities    Activity[]
  tasks         Task[]
  cases         Case[]

  @@map("accounts")
}

model Contact {
  id                      String   @id @default(uuid())
  accountId               String?  @map("account_id")
  firstName               String   @map("first_name")
  lastName                String   @map("last_name")
  email                   String?  @unique
  phone                   String?
  role                    String?
  title                   String?
  communicationPreference String?  @default("email") @map("communication_preference")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at")

  account    Account?   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  activities Activity[]
  tasks      Task[]
  cases      Case[]

  @@index([accountId])
  @@map("contacts")
}

model Opportunity {
  id          String    @id @default(uuid())
  accountId   String?   @map("account_id")
  name        String
  stage       String    @default("Prospecting")
  value       Decimal?
  probability Int?      @default(0)
  closeDate   DateTime? @map("close_date")
  nextSteps   String?   @map("next_steps")
  owner       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  account             Account?             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  activities          Activity[]
  tasks               Task[]
  opportunityProducts OpportunityProduct[]

  @@index([accountId])
  @@index([stage])
  @@map("opportunities")
}

model Activity {
  id            String   @id @default(uuid())
  type          String
  subject       String?
  description   String?
  accountId     String?  @map("account_id")
  contactId     String?  @map("contact_id")
  opportunityId String?  @map("opportunity_id")
  owner         String?
  activityDate  DateTime @default(now()) @map("activity_date")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  account     Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([contactId])
  @@index([opportunityId])
  @@map("activities")
}

model Task {
  id            String    @id @default(uuid())
  title         String
  description   String?
  status        String?   @default("Pending")
  priority      String?   @default("Medium")
  dueDate       DateTime? @map("due_date")
  accountId     String?   @map("account_id")
  contactId     String?   @map("contact_id")
  opportunityId String?   @map("opportunity_id")
  caseId        String?   @map("case_id")
  owner         String?
  completed     Boolean?  @default(false)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  account     Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  case        Case?        @relation(fields: [caseId], references: [id])

  @@index([accountId])
  @@index([opportunityId])
  @@map("tasks")
}

model Case {
  id                 String   @id @default(uuid())
  accountId          String?  @map("account_id")
  contactId          String?  @map("contact_id")
  subject            String
  description        String?
  status             String?  @default("New")
  priority           String?  @default("Medium")
  category           String?
  resolution         String?
  satisfactionRating Int?     @map("satisfaction_rating")
  owner              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  account Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([accountId])
  @@map("cases")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  sku         String?  @unique
  description String?
  price       Decimal?
  status      String?  @default("Active")
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  opportunityProducts OpportunityProduct[]

  @@map("products")
}

model OpportunityProduct {
  id            String   @id @default(uuid())
  opportunityId String?  @map("opportunity_id")
  productId     String?  @map("product_id")
  quantity      Int?     @default(1)
  discount      Decimal? @default(0)
  total         Decimal?
  createdAt     DateTime @default(now()) @map("created_at")

  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  product     Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("opportunity_products")
}
